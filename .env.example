OPENAI_API_KEY=

# Supabase (Phase 2 — create project at https://supabase.com)
SUPABASE_URL=
SUPABASE_ANON_KEY=

# Optional: service role key — only for admin/server tasks, keep secret
# SUPABASE_SERVICE_ROLE_KEY=
